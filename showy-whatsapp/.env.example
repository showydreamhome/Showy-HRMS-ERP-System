# Copy this file to .env and fill the values before running the server
# Example:
# WHATSAPP_TOKEN=EAA...your_token_here...
# PHONE_NUMBER_ID=1234567890

WHATSAPP_TOKEN=
PHONE_NUMBER_ID=

# Notes:
# - `WHATSAPP_TOKEN` should be a long-lived access token for the WhatsApp Business API (Facebook Graph).
# - `PHONE_NUMBER_ID` is the numeric ID for the associated phone number in the WhatsApp Business account.